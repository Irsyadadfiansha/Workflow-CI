name: HeartDiseasePipeline

python_env: conda.yaml

entry_points:
  main:
    parameters:
      data_path:
        default: "heart_disease_preprocess/heart_preprocessed.csv"

      experiment_name:
        default: "Heart-Disease-CI"

    command: >
      python modelling.py
      --data_path {data_path}
      --experiment_name {experiment_name}